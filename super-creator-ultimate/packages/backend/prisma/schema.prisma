generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id          String   @id @default(cuid())
  name        String
  platform    String
  userDataDir String
  proxyUrl    String?
  proxyUser   String?
  proxyPass   String?
  cookies     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
}

model Job {
  id        String   @id @default(cuid())
  type      String
  platform  String
  prompt    String
  status    String
  resultUrl String?
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  createdAt DateTime @default(now())
}

model License {
  id        String   @id @default(cuid())
  key       String   @unique
  machineId String?
  status    String
  expiresAt DateTime?
}

model Setting {
  key   String @id
  value String
}
