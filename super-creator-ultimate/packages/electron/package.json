{
  "name": "@supercreator/electron",
  "version": "0.1.0",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main/index.ts",
    "lint": "echo 'No lint configured for electron'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "echo 'No formatter configured for electron'",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.4",
    "playwright": "^1.47.2",
    "proxy-chain": "^2.5.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.6",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
